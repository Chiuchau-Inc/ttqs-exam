# 複製成 .env(.env 已 gitignore,不入版控)。部署時建議用平台 secret 注入環境變數。
# Dify 出題 App 的 API Key(對應 exam_app/dify_question_gen_prompt.md 那支 App)
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxx
DIFY_BASE_URL=https://api.dify.ai/v1
# 服務埠(與 exam_app 的 8080 錯開)
PORT=8090
# 管理後台 token:設了才驗證 /api/admin/*;正式部署務必設長亂碼
ADMIN_TOKEN=
# 資料目錄(題庫池 + 成績;正式部署掛持久磁碟,如 Zeabur volume 掛 /data)
DATA_DIR=./data
# 速率限制
RATE_PER_MIN=60
RATE_GLOBAL_PER_MIN=600
