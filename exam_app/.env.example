# 複製成 .env（.env 已 gitignore，不入版控）。部署時建議用平台 secret 注入環境變數，不要放明碼檔。
# Dify 應用的 API Key（在 Dify 該 App → API Access 取得，格式 app-xxxx）
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxx
# Dify API 端點（雲端用預設；自架 Dify 改成你的網域 + /v1）
DIFY_BASE_URL=https://api.dify.ai/v1
# 服務埠（本機可用 8080；正式部署由平台注入 PORT）
PORT=8080
# session token 簽章密鑰（多實例務必設同一把；單實例不設則啟動隨機產生）
SESSION_SECRET=
# 是否信任反向代理的 X-Forwarded-For。直曝 Node 一律保持 0；置於可信代理(Nginx/Zeabur)後才設 1
TRUST_PROXY=0
# 每 IP 每分鐘請求上限
RATE_PER_MIN=40
# 全域每分鐘請求上限（保護 Dify 額度）
RATE_GLOBAL_PER_MIN=600
# 允許的來源（逗號分隔完整 origin，如 https://exam.yourdomain.com）；留空=只允許嚴格同源
ALLOW_ORIGINS=
# 排行榜結果持久化目錄（正式部署掛持久磁碟，如 Zeabur volume 掛 /data）
DATA_DIR=./data
# 老師稽核 token：設了才開放 /api/admin/results 與排行榜頁「老師模式」查看作答（請設長亂碼）
ADMIN_TOKEN=
